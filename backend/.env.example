# ╔══════════════════════════════════════════╗
# ║  StockFlow — Variables d'environnement   ║
# ╚══════════════════════════════════════════╝

# PostgreSQL (fourni par Render)
DATABASE_URL=postgresql://user:password@host:5432/stockflow

# JWT Secret (changez ceci en production !)
JWT_SECRET=stockflow_super_secret_key_change_me_in_prod

# Port
PORT=3000

# Environnement
NODE_ENV=production

# URL du frontend (pour CORS)
FRONTEND_URL=https://stockflow.onrender.com

# ─── SUPABASE STORAGE (pour les images) ─────────────────
# Trouver ces valeurs dans: Supabase > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  (service_role key)
SUPABASE_BUCKET=stockflow-images
